+import { afterEach, describe, expect, it, vi } from 'vitest';
+import { fetchServerNetwork, fetchServerNetworkHistory } from '../api';
+
+describe('server network API', () => {
+  afterEach(() => {
+    vi.restoreAllMocks();
+    vi.unstubAllGlobals();
+  });
+
+  it('loads the live summary and 24-hour history through protected usage API paths', async () => {
+    vi.stubGlobal('window', { __APP_BASE_PATH__: '/usage' });
+    const fetchMock = vi.spyOn(globalThis, 'fetch').mockResolvedValue({
+      ok: true,
+      json: async () => ({ points: [] }),
+    } as Response);
+    const signal = new AbortController().signal;
+
+    await fetchServerNetwork(signal);
+    await fetchServerNetworkHistory('24h', signal);
+
+    const summaryURL = new URL(String(fetchMock.mock.calls[0][0]), 'http://localhost');
+    const historyURL = new URL(String(fetchMock.mock.calls[1][0]), 'http://localhost');
+    expect(summaryURL.pathname).toBe('/usage/api/v1/server-network');
+    expect(historyURL.pathname).toBe('/usage/api/v1/server-network/history');
+    expect(historyURL.searchParams.get('range')).toBe('24h');
+    expect(fetchMock.mock.calls[0][1]).toMatchObject({ credentials: 'include', cache: 'no-store', signal });
+    expect(fetchMock.mock.calls[1][1]).toMatchObject({ credentials: 'include', cache: 'no-store', signal });
+  });
+});
