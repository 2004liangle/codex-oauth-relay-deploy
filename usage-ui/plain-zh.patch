@@ -0,0 +1,331 @@
+import { useMemo } from 'react';
+import { useTranslation } from 'react-i18next';
+import type { ChartData, ChartOptions } from 'chart.js';
+import { Line } from 'react-chartjs-2';
+import type { ServerNetworkHistoryResponse, ServerNetworkSummaryResponse } from '@/lib/types';
+import { LoadingSpinner } from '@/components/ui/LoadingSpinner';
+import { IconCircleAlert, IconInfo } from '@/components/ui/icons';
+import styles from './ServerNetworkPanel.module.scss';
+
+export interface ServerNetworkPanelProps {
+  summary: ServerNetworkSummaryResponse | null;
+  history: ServerNetworkHistoryResponse | null;
+  loading: boolean;
+  error?: string;
+  isDark: boolean;
+  isMobile: boolean;
+}
+
+const DECIMAL_UNITS = ['B', 'KB', 'MB', 'GB', 'TB', 'PB'] as const;
+
+const safeNumber = (value: number | null | undefined) => (
+  typeof value === 'number' && Number.isFinite(value) ? Math.max(0, value) : 0
+);
+
+export function formatNetworkBytes(value: number): string {
+  let amount = safeNumber(value);
+  let unitIndex = 0;
+  while (amount >= 1000 && unitIndex < DECIMAL_UNITS.length - 1) {
+    amount /= 1000;
+    unitIndex += 1;
+  }
+  const digits = amount >= 100 || unitIndex === 0 ? 0 : amount >= 10 ? 1 : 2;
+  return `${amount.toFixed(digits)} ${DECIMAL_UNITS[unitIndex]}`;
+}
+
+export function formatNetworkRate(bytesPerSecond: number): string {
+  const bitsPerSecond = safeNumber(bytesPerSecond) * 8;
+  if (bitsPerSecond >= 1_000_000_000) return `${(bitsPerSecond / 1_000_000_000).toFixed(2)} Gbps`;
+  if (bitsPerSecond >= 1_000_000) return `${(bitsPerSecond / 1_000_000).toFixed(2)} Mbps`;
+  if (bitsPerSecond >= 1_000) return `${(bitsPerSecond / 1_000).toFixed(1)} Kbps`;
+  return `${Math.round(bitsPerSecond)} bps`;
+}
+
+function formatChartRate(bytesPerSecond: number): string {
+  const mbps = safeNumber(bytesPerSecond) * 8 / 1_000_000;
+  if (mbps >= 10) return mbps.toFixed(1);
+  return mbps.toFixed(2);
+}
+
+function formatDateTime(value: string | null | undefined, language: string): string {
+  if (!value) return '--';
+  const date = new Date(value);
+  if (Number.isNaN(date.getTime())) return '--';
+  return date.toLocaleString(language, {
+    month: '2-digit',
+    day: '2-digit',
+    hour: '2-digit',
+    minute: '2-digit',
+    second: '2-digit',
+    hour12: false,
+  });
+}
+
+function MetricCard({
+  label,
+  value,
+  detail,
+  tone,
+}: {
+  label: string;
+  value: string;
+  detail?: string;
+  tone: 'receive' | 'send' | 'total';
+}) {
+  return (
+    <div className={`${styles.metricCard} ${styles[tone]}`.trim()}>
+      <span className={styles.metricLabel}>{label}</span>
+      <strong className={styles.metricValue}>{value}</strong>
+      {detail && <span className={styles.metricDetail}>{detail}</span>}
+    </div>
+  );
+}
+
+function NetworkChart({
+  history,
+  isDark,
+  isMobile,
+}: {
+  history: ServerNetworkHistoryResponse | null;
+  isDark: boolean;
+  isMobile: boolean;
+}) {
+  const { t, i18n } = useTranslation();
+  const points = useMemo(() => history?.points ?? [], [history?.points]);
+  const labels = useMemo(() => points.map((point) => {
+    const date = new Date(point.timestamp);
+    if (Number.isNaN(date.getTime())) return '--';
+    return date.toLocaleTimeString(i18n.resolvedLanguage ?? i18n.language, {
+      hour: '2-digit',
+      minute: '2-digit',
+      hour12: false,
+    });
+  }), [i18n.language, i18n.resolvedLanguage, points]);
+
+  const chartData = useMemo<ChartData<'line', number[], string>>(() => ({
+    labels,
+    datasets: [
+      {
+        label: t('usage_stats.network_receive'),
+        data: points.map((point) => safeNumber(point.rx_bytes_per_sec) * 8 / 1_000_000),
+        borderColor: '#0891b2',
+        backgroundColor: 'rgba(8, 145, 178, 0.12)',
+        borderWidth: isMobile ? 1.5 : 2,
+        pointRadius: 0,
+        pointHoverRadius: 3,
+        tension: 0.28,
+        fill: true,
+      },
+      {
+        label: t('usage_stats.network_send'),
+        data: points.map((point) => safeNumber(point.tx_bytes_per_sec) * 8 / 1_000_000),
+        borderColor: '#ea580c',
+        backgroundColor: 'rgba(234, 88, 12, 0.08)',
+        borderWidth: isMobile ? 1.5 : 2,
+        pointRadius: 0,
+        pointHoverRadius: 3,
+        tension: 0.28,
+        fill: true,
+      },
+    ],
+  }), [isMobile, labels, points, t]);
+
+  const chartOptions = useMemo<ChartOptions<'line'>>(() => {
+    const gridColor = isDark ? 'rgba(255, 255, 255, 0.08)' : 'rgba(17, 24, 39, 0.08)';
+    const tickColor = isDark ? 'rgba(255, 255, 255, 0.68)' : 'rgba(17, 24, 39, 0.68)';
+    const tooltipText = isDark ? '#ffffff' : '#111827';
+    return {
+      responsive: true,
+      maintainAspectRatio: false,
+      interaction: { mode: 'index', intersect: false },
+      animation: { duration: 180 },
+      plugins: {
+        legend: {
+          position: 'top',
+          align: 'end',
+          labels: { color: tickColor, boxWidth: 12, boxHeight: 3, usePointStyle: true },
+        },
+        tooltip: {
+          backgroundColor: isDark ? 'rgba(17, 24, 39, 0.96)' : 'rgba(255, 255, 255, 0.98)',
+          titleColor: tooltipText,
+          bodyColor: tooltipText,
+          borderColor: gridColor,
+          borderWidth: 1,
+          callbacks: {
+            label: (context) => `${context.dataset.label}: ${Number(context.parsed.y ?? 0).toFixed(2)} Mbps`,
+          },
+        },
+      },
+      scales: {
+        x: {
+          grid: { display: false },
+          border: { color: gridColor },
+          ticks: { color: tickColor, maxTicksLimit: isMobile ? 5 : 10, font: { size: isMobile ? 10 : 11 } },
+        },
+        y: {
+          beginAtZero: true,
+          grid: { color: gridColor },
+          border: { color: gridColor },
+          title: { display: !isMobile, text: 'Mbps', color: tickColor },
+          ticks: { color: tickColor, callback: (value) => formatChartRate(Number(value) * 1_000_000 / 8) },
+        },
+      },
+    };
+  }, [isDark, isMobile]);
+
+  return (
+    <div className={styles.chartFrame} aria-label={t('usage_stats.network_chart_title')}>
+      <Line data={chartData} options={chartOptions} />
+      {points.length === 0 && (
+        <div className={styles.chartEmpty}>{t('usage_stats.network_chart_empty')}</div>
+      )}
+    </div>
+  );
+}
+
+export function ServerNetworkPanel({
+  summary,
+  history,
+  loading,
+  error,
+  isDark,
+  isMobile,
+}: ServerNetworkPanelProps) {
+  const { t, i18n } = useTranslation();
+  const language = i18n.resolvedLanguage ?? i18n.language;
+  const packageUsage = summary?.package;
+  const packagePercent = safeNumber(packageUsage?.percent);
+  const packageBarPercent = Math.min(100, packagePercent);
+  const packageConfigured = packageUsage?.configured === true && safeNumber(packageUsage.total_bytes) > 0;
+  const initialLoading = !summary && (loading || !error);
+
+  return (
+    <section className={styles.panel} aria-labelledby="server-network-title">
+      <div className={styles.headingRow}>
+        <div>
+          <h2 id="server-network-title" className={styles.title}>{t('usage_stats.network_title')}</h2>
+          <p className={styles.subtitle}>{t('usage_stats.network_subtitle')}</p>
+        </div>
+        <div className={styles.statusCluster}>
+          {initialLoading ? (
+            <span className={styles.statusPill}><LoadingSpinner size={12} />{t('common.loading')}</span>
+          ) : summary ? (
+            <span className={`${styles.statusPill} ${summary?.stale ? styles.statusStale : styles.statusLive}`.trim()}>
+              <span className={styles.statusDot} aria-hidden="true" />
+              {summary?.stale ? t('usage_stats.network_status_stale') : t('usage_stats.network_status_live')}
+            </span>
+          ) : (
+            <span className={`${styles.statusPill} ${styles.statusUnavailable}`.trim()}>
+              <span className={styles.statusDot} aria-hidden="true" />
+              {t('usage_stats.network_status_unavailable')}
+            </span>
+          )}
+          <span className={styles.interfacePill}>{t('usage_stats.network_interface')}: {summary?.interface || '--'}</span>
+        </div>
+      </div>
+
+      {error && (
+        <div className={styles.errorBanner} role="alert">
+          <IconCircleAlert size={16} />
+          <span>{t('usage_stats.network_load_failed')}</span>
+        </div>
+      )}
+
+      <div className={styles.sectionHeader}>
+        <h3>{t('usage_stats.network_realtime_title')}</h3>
+        <span>{t('usage_stats.network_refresh_hint')}</span>
+      </div>
+      <div className={styles.metricGrid} aria-live="polite">
+        <MetricCard
+          tone="receive"
+          label={t('usage_stats.network_receive_speed')}
+          value={summary ? formatNetworkRate(summary.current.rx_bytes_per_sec) : '--'}
+          detail={`${t('usage_stats.network_peak')}: ${summary ? formatNetworkRate(summary.peak.rx_bytes_per_sec) : '--'}`}
+        />
+        <MetricCard
+          tone="send"
+          label={t('usage_stats.network_send_speed')}
+          value={summary ? formatNetworkRate(summary.current.tx_bytes_per_sec) : '--'}
+          detail={`${t('usage_stats.network_peak')}: ${summary ? formatNetworkRate(summary.peak.tx_bytes_per_sec) : '--'}`}
+        />
+        <MetricCard
+          tone="total"
+          label={t('usage_stats.network_total_speed')}
+          value={summary ? formatNetworkRate(summary.current.total_bytes_per_sec) : '--'}
+          detail={`${t('usage_stats.network_peak')}: ${summary ? formatNetworkRate(summary.peak.total_bytes_per_sec) : '--'}`}
+        />
+      </div>
+
+      <div className={styles.sectionHeader}>
+        <h3>{t('usage_stats.network_accumulated_title')}</h3>
+        <span>{t('usage_stats.network_started_at')}: {formatDateTime(summary?.monitor_started_at, language)}</span>
+      </div>
+      <div className={styles.metricGrid}>
+        <MetricCard tone="receive" label={t('usage_stats.network_received')} value={summary ? formatNetworkBytes(summary.monitored.rx_bytes) : '--'} />
+        <MetricCard tone="send" label={t('usage_stats.network_sent')} value={summary ? formatNetworkBytes(summary.monitored.tx_bytes) : '--'} />
+        <MetricCard tone="total" label={t('usage_stats.network_total')} value={summary ? formatNetworkBytes(summary.monitored.total_bytes) : '--'} />
+      </div>
+
+      <div className={styles.sinceBootBand}>
+        <div className={styles.sinceBootHeading}>
+          <div>
+            <h3>{t('usage_stats.network_since_boot_title')}</h3>
+            <p>{t('usage_stats.network_since_boot_hint')}</p>
+          </div>
+          {summary && summary.reset_count > 0 && (
+            <span className={styles.resetCount}>{t('usage_stats.network_counter_reset', { count: summary.reset_count })}</span>
+          )}
+        </div>
+        <div className={styles.sinceBootValues}>
+          <span>{t('usage_stats.network_receive')}: <strong>{summary ? formatNetworkBytes(summary.since_boot.rx_bytes) : '--'}</strong></span>
+          <span>{t('usage_stats.network_send')}: <strong>{summary ? formatNetworkBytes(summary.since_boot.tx_bytes) : '--'}</strong></span>
+          <span>{t('usage_stats.network_total')}: <strong>{summary ? formatNetworkBytes(summary.since_boot.total_bytes) : '--'}</strong></span>
+        </div>
+      </div>
+
+      <div className={styles.packageBand}>
+        <div className={styles.packageHeader}>
+          <div>
+            <h3>{t('usage_stats.network_package_title')}</h3>
+            <p>{t('usage_stats.network_package_outbound_hint')}</p>
+          </div>
+          {packageConfigured ? (
+            <strong>{formatNetworkBytes(packageUsage.used_bytes)} / {formatNetworkBytes(packageUsage.total_bytes)}</strong>
+          ) : (
+            <strong className={styles.packageUnset}>{t('usage_stats.network_package_unconfigured')}</strong>
+          )}
+        </div>
+        {packageConfigured && (
+          <>
+            <div className={styles.progressTrack} role="progressbar" aria-valuemin={0} aria-valuemax={100} aria-valuenow={packageBarPercent}>
+              <span style={{ width: `${packageBarPercent}%` }} />
+            </div>
+            <div className={styles.packageMeta}>
+              <span>{t('usage_stats.network_package_used')}: {packagePercent.toFixed(1)}%</span>
+              <span>{t('usage_stats.network_package_remaining')}: {formatNetworkBytes(packageUsage.remaining_bytes)}</span>
+              {(packageUsage.start_at || packageUsage.end_at) && (
+                <span>{formatDateTime(packageUsage.start_at, language)} - {formatDateTime(packageUsage.end_at, language)}</span>
+              )}
+            </div>
+          </>
+        )}
+      </div>
+
+      <div className={styles.chartSection}>
+        <div className={styles.sectionHeader}>
+          <h3>{t('usage_stats.network_chart_title')}</h3>
+          <span>{t('usage_stats.network_chart_subtitle')}</span>
+        </div>
+        <NetworkChart history={history} isDark={isDark} isMobile={isMobile} />
+      </div>
+
+      <div className={styles.notice}>
+        <IconInfo size={17} />
+        <div>
+          <strong>{t('usage_stats.network_estimate_title')}</strong>
+          <p>{t('usage_stats.network_estimate_notice')}</p>
+        </div>
+      </div>
+    </section>
+  );
+}
