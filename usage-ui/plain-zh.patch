+import { afterAll, beforeAll, describe, expect, it } from 'vitest';
+import i18n from '@/i18n';
+import { formatCompactNumber, formatCompactTokenValue, formatDurationMs } from '@/utils/usage';
+
+describe('plain Simplified Chinese display', () => {
+  const previousLanguage = i18n.resolvedLanguage || i18n.language;
+
+  beforeAll(async () => {
+    await i18n.changeLanguage('zh');
+  });
+
+  afterAll(async () => {
+    await i18n.changeLanguage(previousLanguage);
+  });
+
+  it('uses plain Simplified Chinese and keeps technical identifiers in parentheses', () => {
+    expect(i18n.t('usage_stats.tab_overview')).toBe('总体情况');
+    expect(i18n.t('usage_stats.tab_events')).toBe('每次请求');
+    expect(i18n.t('usage_stats.tab_auth_files')).toBe('登录账号');
+    expect(i18n.t('usage_stats.session_settings_title')).toBe('登录设备管理');
+    expect(i18n.t('usage_stats.total_tokens')).toBe('总用量（Token）');
+    expect(i18n.t('usage_stats.total_cost')).toBe('估算费用（仅供参考）');
+  });
+
+  it('explains realtime windows, rates and reasoning levels without raw shorthand', () => {
+    expect(i18n.t('usage_stats.overview_realtime_tpm')).toBe('每分钟总用量（Token）');
+    expect(i18n.t('usage_stats.overview_realtime_window_15m')).toBe('近 15 分钟');
+    expect(i18n.t('usage_stats.overview_realtime_window_60m')).toBe('近 1 小时');
+    expect(i18n.t('usage_stats.overview_realtime_per_minute_value', { value: '2万' })).toBe('每分钟 2万');
+    expect(i18n.t('usage_stats.speed_value', { value: '12.5' })).toBe('每秒 12.5 个 Token');
+    expect(i18n.t('usage_stats.reasoning_effort_low')).toBe('较少思考');
+    expect(i18n.t('usage_stats.reasoning_effort_medium')).toBe('正常思考');
+    expect(i18n.t('usage_stats.reasoning_effort_high')).toBe('深入思考');
+    expect(i18n.t('usage_stats.reasoning_effort_unknown', { value: 'ultra' })).toBe('其他（ultra）');
+    expect(i18n.t('usage_stats.speed_mode_batch')).toBe('批量处理');
+    expect(i18n.t('usage_stats.request_type_sse')).toBe('流式回复（SSE）');
+    expect(i18n.t('usage_stats.request_type_ws')).toBe('实时连接（WS）');
+    expect(i18n.t('usage_stats.analysis_latency_p95_ttft')).toBe('95% 的请求在此时间内开始回复');
+    expect(i18n.t('usage_stats.analysis_latency_p95_latency')).toBe('95% 的请求在此时间内全部完成');
+  });
+
+  it('uses readable quota periods, countdowns and price units', () => {
+    expect(i18n.t('usage_stats.credentials_quota_label_5h')).toBe('5 小时额度');
+    expect(i18n.t('usage_stats.credentials_quota_label_weekly')).toBe('每周额度');
+    expect(i18n.t('usage_stats.credentials_quota_reset_duration_days', {
+      days: '2',
+      hours: '3',
+      minutes: '4',
+    })).toBe('2天 3小时 4分钟');
+    expect(i18n.t('usage_stats.model_price_unit_per_million')).toBe('美元 / 每 100 万 Token');
+    expect(i18n.t('usage_stats.model_price_match_exact')).toBe('名称完全匹配');
+  });
+
+  it('uses Chinese large-number and duration units', () => {
+    expect(formatCompactNumber(1_200)).toBe('1,200');
+    expect(formatCompactNumber(12_000)).toBe('1.2万');
+    expect(formatCompactNumber(125_000_000)).toBe('1.25亿');
+    expect(formatCompactTokenValue(20_000, true)).toBe('2万 个 Token');
+    expect(formatDurationMs(850)).toBe('850毫秒');
+    expect(formatDurationMs(1_500)).toBe('1.5秒');
+    expect(formatDurationMs(61_000)).toBe('1分钟 01秒');
+  });
+});
