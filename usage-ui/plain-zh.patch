+
+.metricDetail {
+  margin-top: auto;
+  padding-top: 8px;
+  color: var(--text-secondary);
+  font-size: 11px;
+  font-variant-numeric: tabular-nums;
+}
+
+.packageBand,
+.chartSection {
+  padding: 16px;
+  border: 1px solid var(--border-color);
+  border-radius: 8px;
+  background: var(--bg-primary);
+}
+
+.packageHeader strong {
+  color: var(--text-primary);
+  font-size: 14px;
+  font-variant-numeric: tabular-nums;
+  text-align: right;
+}
+
+.packageHeader .packageUnset {
+  color: var(--text-secondary);
+  font-weight: 600;
+}
+
+.progressTrack {
+  height: 9px;
+  margin-top: 15px;
+  border-radius: 999px;
+  background: color-mix(in srgb, var(--border-color) 70%, var(--bg-secondary));
+  overflow: hidden;
+
+  span {
+    display: block;
+    height: 100%;
+    border-radius: inherit;
+    background: #0f766e;
+    transition: width 0.25s ease;
+  }
+}
+
+.packageMeta {
+  margin-top: 9px;
+  color: var(--text-secondary);
+  font-size: 11px;
+  font-variant-numeric: tabular-nums;
+  flex-wrap: wrap;
+}
+
+.chartSection {
+  min-width: 0;
+}
+
+.chartSection .sectionHeader {
+  margin-bottom: 12px;
+}
+
+.chartFrame {
+  position: relative;
+  width: 100%;
+  height: 320px;
+}
+
+.chartEmpty {
+  position: absolute;
+  inset: 42px 0 0;
+  display: grid;
+  place-items: center;
+  color: var(--text-secondary);
+  font-size: 13px;
+  background: color-mix(in srgb, var(--bg-primary) 82%, transparent);
+}
+
+.notice {
+  color: var(--text-secondary);
+  border-color: color-mix(in srgb, #0284c7 28%, var(--border-color));
+  background: color-mix(in srgb, #0284c7 6%, var(--bg-primary));
+}
+
+.notice svg {
+  flex: 0 0 auto;
+  margin-top: 2px;
+  color: #0284c7;
+}
+
+.notice strong {
+  color: var(--text-primary);
+  font-size: 13px;
+}
+
+@media (max-width: 768px) {
+  .headingRow,
+  .packageHeader {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .statusCluster {
+    justify-content: flex-start;
+  }
+
+  .metricGrid {
+    grid-template-columns: 1fr;
+  }
+
+  .metricCard {
+    min-height: 102px;
+  }
+
+  .metricValue {
+    font-size: 23px;
+  }
+
+  .sinceBootBand,
+  .sinceBootHeading,
+  .sinceBootValues {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .sinceBootValues {
+    gap: 5px;
+    white-space: normal;
+  }
+
+  .sectionHeader {
+    align-items: flex-start;
+    flex-direction: column;
+    gap: 3px;
+  }
+
+  .packageHeader strong {
+    text-align: left;
+  }
+
+  .packageMeta {
+    align-items: flex-start;
+    flex-direction: column;
+    gap: 4px;
+  }
+
+  .chartFrame {
+    height: 270px;
+  }
+}
