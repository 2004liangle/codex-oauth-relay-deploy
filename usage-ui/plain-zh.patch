+import { createElement } from 'react';
+import { describe, expect, it } from 'vitest';
+import { renderToStaticMarkup } from 'react-dom/server';
+import '@/i18n';
+import type { ServerNetworkSummaryResponse } from '@/lib/types';
+import { formatNetworkBytes, formatNetworkRate, ServerNetworkPanel } from './ServerNetworkPanel';
+
+const summary: ServerNetworkSummaryResponse = {
+  generated_at: '2026-07-18T12:00:00Z',
+  stale: false,
+  interface: 'eth0',
+  monitor_started_at: '2026-07-18T11:00:00Z',
+  current: { rx_bytes_per_sec: 1_000_000, tx_bytes_per_sec: 2_000_000, total_bytes_per_sec: 3_000_000 },
+  peak: { rx_bytes_per_sec: 4_000_000, tx_bytes_per_sec: 5_000_000, total_bytes_per_sec: 9_000_000 },
+  monitored: { rx_bytes: 3_000_000_000, tx_bytes: 2_000_000_000, total_bytes: 5_000_000_000 },
+  since_boot: { rx_bytes: 9_000_000_000, tx_bytes: 8_000_000_000, total_bytes: 17_000_000_000 },
+  package: {
+    configured: true,
+    total_bytes: 100_000_000_000,
+    used_bytes: 25_000_000_000,
+    remaining_bytes: 75_000_000_000,
+    percent: 25,
+    start_at: '2026-07-01T00:00:00Z',
+    end_at: '2026-07-31T23:59:59Z',
+  },
+  reset_count: 0,
+};
+
+describe('ServerNetworkPanel formatting', () => {
+  it('uses decimal traffic units and network bit-rate units', () => {
+    expect(formatNetworkBytes(1_000_000_000)).toBe('1.00 GB');
+    expect(formatNetworkRate(1_000_000)).toBe('8.00 Mbps');
+  });
+
+  it('renders live, accumulated, package, and estimate sections', () => {
+    const html = renderToStaticMarkup(createElement(ServerNetworkPanel, {
+      summary,
+      history: { generated_at: summary.generated_at, range: '24h', points: [] },
+      loading: false,
+      isDark: false,
+      isMobile: false,
+    }));
+
+    expect(html).toContain('Server network traffic');
+    expect(html).toContain('8.00 Mbps');
+    expect(html).toContain('25.0%');
+    expect(html).toContain('Local interface estimate');
+    expect(html).toContain('Traffic since this system boot');
+    expect(html).toContain('17.0 GB');
+  });
+
+  it('keeps an over-quota percentage visible while limiting the progress bar width', () => {
+    const html = renderToStaticMarkup(createElement(ServerNetworkPanel, {
+      summary: { ...summary, package: { ...summary.package, percent: 125, used_bytes: 125_000_000_000, remaining_bytes: 0 } },
+      history: null,
+      loading: false,
+      isDark: false,
+      isMobile: false,
+    }));
+
+    expect(html).toContain('125.0%');
+    expect(html).toContain('aria-valuenow="100"');
+    expect(html).toContain('width:100%');
+  });
+});
