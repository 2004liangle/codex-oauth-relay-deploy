+.panel {
+  display: flex;
+  flex-direction: column;
+  gap: 18px;
+  min-width: 0;
+}
+
+.headingRow,
+.sectionHeader,
+.packageHeader,
+.packageMeta {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 14px;
+}
+
+.title,
+.sectionHeader h3,
+.packageHeader h3 {
+  margin: 0;
+  color: var(--text-primary);
+  letter-spacing: 0;
+}
+
+.title {
+  font-size: 20px;
+  line-height: 1.3;
+}
+
+.subtitle,
+.packageHeader p,
+.notice p {
+  margin: 5px 0 0;
+  color: var(--text-secondary);
+  font-size: 13px;
+  line-height: 1.55;
+}
+
+.statusCluster {
+  display: flex;
+  align-items: center;
+  justify-content: flex-end;
+  gap: 8px;
+  flex-wrap: wrap;
+}
+
+.statusPill,
+.interfacePill {
+  display: inline-flex;
+  align-items: center;
+  gap: 7px;
+  min-height: 30px;
+  padding: 0 10px;
+  border: 1px solid var(--border-color);
+  border-radius: 999px;
+  background: var(--bg-primary);
+  color: var(--text-secondary);
+  font-size: 12px;
+  white-space: nowrap;
+}
+
+.statusDot {
+  width: 7px;
+  height: 7px;
+  border-radius: 50%;
+  background: currentColor;
+}
+
+.statusLive {
+  color: #0f766e;
+  border-color: color-mix(in srgb, #0f766e 30%, var(--border-color));
+}
+
+.statusStale {
+  color: #b45309;
+  border-color: color-mix(in srgb, #b45309 30%, var(--border-color));
+}
+
+.statusUnavailable {
+  color: #b91c1c;
+  border-color: color-mix(in srgb, #b91c1c 30%, var(--border-color));
+}
+
+.errorBanner,
+.notice {
+  display: flex;
+  align-items: flex-start;
+  gap: 10px;
+  padding: 12px 14px;
+  border: 1px solid color-mix(in srgb, #dc2626 30%, var(--border-color));
+  border-radius: 8px;
+  background: color-mix(in srgb, #dc2626 7%, var(--bg-primary));
+  color: #b91c1c;
+  font-size: 13px;
+}
+
+.sectionHeader {
+  align-items: baseline;
+  margin-bottom: -8px;
+}
+
+.sectionHeader h3,
+.packageHeader h3 {
+  font-size: 15px;
