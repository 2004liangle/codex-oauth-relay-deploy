diff --git a/web/src/components/usage/hooks/useServerNetworkData.ts b/web/src/components/usage/hooks/useServerNetworkData.ts
new file mode 100644
index 0000000000000000000000000000000000000000..5f135910fce1c54b50d7c30786af4396389bef38
--- /dev/null
+++ b/web/src/components/usage/hooks/useServerNetworkData.ts
@@ -0,0 +1,133 @@
+import { useCallback, useEffect, useRef, useState } from 'react';
+import { ApiError, fetchServerNetwork, fetchServerNetworkHistory } from '@/lib/api';
+import type { ServerNetworkHistoryResponse, ServerNetworkSummaryResponse } from '@/lib/types';
+
+const SUMMARY_REFRESH_INTERVAL_MS = 2_000;
+const HISTORY_REFRESH_INTERVAL_MS = 60_000;
+
+export interface UseServerNetworkDataOptions {
+  enabled?: boolean;
+  onAuthRequired?: () => void;
+}
+
+export interface UseServerNetworkDataReturn {
+  summary: ServerNetworkSummaryResponse | null;
+  history: ServerNetworkHistoryResponse | null;
+  loading: boolean;
+  error: string;
+  loadNetwork: () => Promise<void>;
+}
+
+const isPageVisible = () => typeof document === 'undefined' || document.visibilityState !== 'hidden';
+
+export function useServerNetworkData({
+  enabled = true,
+  onAuthRequired,
+}: UseServerNetworkDataOptions = {}): UseServerNetworkDataReturn {
+  const [summary, setSummary] = useState<ServerNetworkSummaryResponse | null>(null);
+  const [history, setHistory] = useState<ServerNetworkHistoryResponse | null>(null);
+  const [loading, setLoading] = useState(false);
+  const [error, setError] = useState('');
+  const [pageVisible, setPageVisible] = useState(isPageVisible);
+  const summaryControllerRef = useRef<AbortController | null>(null);
+  const historyControllerRef = useRef<AbortController | null>(null);
+  const onAuthRequiredRef = useRef(onAuthRequired);
+
+  useEffect(() => {
+    onAuthRequiredRef.current = onAuthRequired;
+  }, [onAuthRequired]);
+
+  useEffect(() => {
+    if (typeof document === 'undefined') return;
+    const handleVisibilityChange = () => setPageVisible(isPageVisible());
+    document.addEventListener('visibilitychange', handleVisibilityChange);
+    return () => document.removeEventListener('visibilitychange', handleVisibilityChange);
+  }, []);
+
+  const handleLoadError = useCallback((loadError: unknown) => {
+    if (loadError instanceof ApiError && loadError.status === 401) {
+      onAuthRequiredRef.current?.();
+      return;
+    }
+    setError(loadError instanceof Error ? loadError.message : 'Failed to load server network usage');
+  }, []);
+
+  const loadSummary = useCallback(async () => {
+    summaryControllerRef.current?.abort();
+    const controller = new AbortController();
+    summaryControllerRef.current = controller;
+    try {
+      const response = await fetchServerNetwork(controller.signal);
+      if (summaryControllerRef.current !== controller) return;
+      setSummary(response);
+      setError('');
+    } catch (loadError) {
+      if (!controller.signal.aborted) handleLoadError(loadError);
+    } finally {
+      if (summaryControllerRef.current === controller) summaryControllerRef.current = null;
+    }
+  }, [handleLoadError]);
+
+  const loadHistory = useCallback(async () => {
+    historyControllerRef.current?.abort();
+    const controller = new AbortController();
+    historyControllerRef.current = controller;
+    try {
+      const response = await fetchServerNetworkHistory('24h', controller.signal);
+      if (historyControllerRef.current !== controller) return;
+      setHistory(response);
+      setError('');
+    } catch (loadError) {
+      if (!controller.signal.aborted) handleLoadError(loadError);
+    } finally {
+      if (historyControllerRef.current === controller) historyControllerRef.current = null;
+    }
+  }, [handleLoadError]);
+
+  const loadNetwork = useCallback(async () => {
+    setLoading(true);
+    await Promise.all([loadSummary(), loadHistory()]);
+    setLoading(false);
+  }, [loadHistory, loadSummary]);
+
+  useEffect(() => {
+    if (!enabled || !pageVisible) {
+      summaryControllerRef.current?.abort();
+      historyControllerRef.current?.abort();
+      summaryControllerRef.current = null;
+      historyControllerRef.current = null;
+      setLoading(false);
+      return;
+    }
+
+    let cancelled = false;
+    let summaryTimer: ReturnType<typeof window.setTimeout> | null = null;
+    let historyTimer: ReturnType<typeof window.setTimeout> | null = null;
+
+    const pollSummary = async () => {
+      await loadSummary();
+      if (!cancelled) summaryTimer = window.setTimeout(pollSummary, SUMMARY_REFRESH_INTERVAL_MS);
+    };
+    const pollHistory = async () => {
+      await loadHistory();
+      if (!cancelled) historyTimer = window.setTimeout(pollHistory, HISTORY_REFRESH_INTERVAL_MS);
+    };
+
+    setLoading(true);
+    void Promise.all([pollSummary(), pollHistory()]).finally(() => {
+      if (!cancelled) setLoading(false);
+    });
+
+    return () => {
+      cancelled = true;
+      if (summaryTimer !== null) window.clearTimeout(summaryTimer);
+      if (historyTimer !== null) window.clearTimeout(historyTimer);
+      summaryControllerRef.current?.abort();
+      historyControllerRef.current?.abort();
+      summaryControllerRef.current = null;
+      historyControllerRef.current = null;
+    };
+  }, [enabled, loadHistory, loadSummary, pageVisible]);
+
+  return { summary, history, loading, error, loadNetwork };
+}
